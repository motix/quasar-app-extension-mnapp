{
  "name": "mnapp-dev",
  "description": "Dev for mnapp",
  "productName": "mnapp Dev",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "postinstall": "cross-env FIREBASE_ENV=PROD quasar prepare",
    "clean": "yarn format --log-level warn && yarn lint --fix",
    "tsc": "yarn vue-tsc --noEmit --skipLibCheck",
    "i-mnapp": "quasar ext invoke @motinet/mnapp && yarn format --log-level warn",
    "u-mnapp": "quasar ext uninvoke @motinet/mnapp && yarn && yarn format --log-level warn",
    "r-mnapp": "quasar ext uninvoke @motinet/mnapp && quasar ext invoke @motinet/mnapp && yarn clean",
    "dev": "cross-env FIREBASE_ENV=DEV quasar dev",
    "devp": "cross-env FIREBASE_ENV=PROD quasar dev",
    "dev:build": "cross-env FIREBASE_ENV=DEV quasar build",
    "stage:build": "cross-env FIREBASE_ENV=STAGE quasar build",
    "prod:build": "cross-env FIREBASE_ENV=PROD quasar build",
    "dev:deploy": "yarn dev:build && firebase deploy",
    "stage:deploy": "yarn stage:build && firebase deploy",
    "prod:deploy": "yarn prod:build && firebase deploy",
    "prod:deploy:debug": "yarn prod:build --debug && firebase deploy"
  },
  "dependencies": {
    "@automapper/core": "^8.8.1",
    "@automapper/pojos": "^8.8.1",
    "@fortawesome/fontawesome-pro": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/pro-duotone-svg-icons": "^7.2.0",
    "@fortawesome/pro-light-svg-icons": "^7.2.0",
    "@fortawesome/pro-regular-svg-icons": "^7.2.0",
    "@fortawesome/pro-solid-svg-icons": "^7.2.0",
    "@fortawesome/pro-thin-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@quasar/extras": "^1.18.0",
    "@vee-validate/yup": "^4.15.1",
    "apexcharts": "^5.10.6",
    "axios": "^1.14.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.12.0",
    "js-guid": "^1.0.2",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "slack": "^11.0.2",
    "slack-message-parser": "^3.0.2",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.32",
    "vue-component-type-helpers": "^3.2.6",
    "vue-markdown-render": "^2.3.0",
    "vue-router": "^5.0.4",
    "vue3-apexcharts": "^1.11.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@motinet/quasar-app-extension-mnapp": "workspace:*",
    "@quasar/app-vite": "^2.6.0",
    "@types/file-saver": "^2.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@vue/compiler-sfc": "^3.5.31",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-checker": "patch:vite-plugin-checker@npm%3A0.12.0#~/.yarn/patches/vite-plugin-checker-npm-0.12.0-0000000000.patch",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  }
}
