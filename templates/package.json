{
  "name": "mnapp-templates",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./modules/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path ../dev/.gitignore",
    "clean": "yarn format --log-level warn && yarn lint --fix",
    "tsc": "yarn vue-tsc --noEmit --skipLibCheck"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "prettier": "^3.8.3",
    "globals": "^17.5.0",
    "@eslint/js": "^10.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint-plugin-vue": "^10.8.0",
    "vue-eslint-parser": "^10.4.0",
    "typescript": "^5.9.3",
    "@quasar/app-vite": "^2.6.0",
    "quasar": "^2.19.3",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.6"
  }
}