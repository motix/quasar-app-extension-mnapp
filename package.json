{
  "name": "@motinet/quasar-app-extension-mnapp",
  "version": "2.1.6",
  "description": "MotiNet Quasar Starter Kit as an App Extension",
  "author": "Minh Nguyen <minh.nguyen@motiteam.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "echo \"No test specified\" && exit 0",
    "postinstall": "node scripts/bundle-prettier-plugin-sort-imports.js && yarn dlx @yarnpkg/sdks vscode && prettier --write ./.vscode/*.*",
    "lint": "eslint -c ./eslint.config.js \"./src/**/*.{ts,js,cjs,mjs,vue}\" && cd ./templates && yarn lint && cd ../dev && yarn lint",
    "lintf": "eslint -c ./eslint.config.js \"./src/**/*.{ts,js,cjs,mjs,vue}\" --fix && cd ./templates && yarn lint --fix && cd ../dev && yarn lint --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,css,scss,html,md,json}\" --ignore-path dev/.gitignore --ignore-path .prettierignore",
    "clean": "yarn format --log-level warn && yarn lintf",
    "build": "yarn tsc && cd ./templates && yarn tsc && cd ../dev && yarn tsc",
    "watch": "yarn tsc --watch",
    "buildPaths": "cd ./templates && node ./buildPaths.js && yarn prettier --write ./tsconfig-paths.json"
  },
  "workspaces": [
    "templates",
    "dev"
  ],
  "dependencies": {
    "@quasar/app-vite": "patch:@quasar/app-vite@npm%3A2.5.4#~/.yarn/patches/@quasar-app-vite-npm-2.5.4-0000000000.patch",
    "@types/lodash-es": "^4.17.12",
    "dotenv": "^17.4.2",
    "firebase": "^12.12.0",
    "lodash-es": "^4.18.1",
    "quasar": "^2.19.3",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vue/compiler-sfc": "^3.5.32",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^10.4.0"
  },
  "dependenciesMeta": {
    "vite-plugin-checker": {
      "unplugged": true
    }
  },
  "engines": {
    "node": ">= 12.2.0",
    "npm": ">= 5.6.0",
    "yarn": ">= 1.6.0"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
